# Suno API Configuration
SUNO_API_KEY=your_suno_api_key_here
SUNO_API_BASE=https://api.suno.com

# A2H Platform (injected by platform, shown for local dev)
A2H_TOKEN=dummy
A2H_API_BASE=http://localhost:9999
A2H_LLM_TOKEN=your_claude_api_token
AWS_REGION=us-east-1

# Agent Settings
AGENT_NAME=AI音乐创作助手
DEFAULT_DURATION=60
A2H_MODEL_ID=us.anthropic.claude-sonnet-4-6
A2H_MAX_TOKENS=2048
A2H_MAX_TOOL_ROUNDS=6
